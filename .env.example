# ============================================
# LuminaFlow ERP - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Used by the Express backend (server/)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- 2FA (TOTP) ---
# Chave dedicada para criptografia de segredos 2FA. Se não definida, usa SUPABASE_SERVICE_ROLE_KEY.
# Em produção, defina uma chave AES-256 dedicada (32+ chars). Sem ela, endpoints 2FA retornam 503.
TOTP_ENCRYPTION_KEY=

# --- Server ---
PORT=8787
NODE_ENV=development

# --- Mercado Pago ---
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# --- API URLs ---
# Frontend uses this to know where the Express backend is
VITE_API_BASE_URL=http://localhost:8787

# --- CORS ---
# Comma-separated list of allowed origins (leave empty for defaults: localhost + clinxia.vercel.app)
ALLOWED_ORIGINS=https://seu-app.vercel.app,http://localhost:5173
FRONTEND_URL=https://seu-app.vercel.app

# --- Gemini AI (optional) ---
GEMINI_API_KEY=

# --- WhatsApp (Baileys) ---
# No env needed - credentials stored in Supabase

# --- Logging ---
LOG_LEVEL=info
